# .env.example — LocalCMS Host Minimal
# Copier ce fichier en .env et adapter les valeurs à votre environnement réel.
# Les valeurs ci-dessous sont des PLACEHOLDERS DE DOCUMENTATION uniquement.
# Elles ne correspondent PAS à des chemins live prouvés sur votre machine.

# Racine du dossier partagé utilisé par M1 (shared_explorer) et M2 (cms_installer).
# M1 : sert les fichiers de ce dossier via /api/shared/*
# M2 : installe les bundles dans des sous-dossiers de ce dossier
# Remplacer par le chemin absolu réel sur votre système.
LOCALCMS_SHARED_ROOT=

# Dossier cible d'installation des modules JS par M2 (cms_installer).
# Correspond à target_key="modules_dir" dans les manifestes de bundle.
# Remplacer par le chemin absolu réel du dossier modules de LocalCMS.
LOCALCMS_MODULES_DIR=

# Port d'écoute du serveur uvicorn.
PORT=8000
